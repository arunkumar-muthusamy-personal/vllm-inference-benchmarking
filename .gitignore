# ── Model weights ────────────────────────────────────────────
# Large binary files — download separately, never commit
models/

# ── LMCache KV cache data ─────────────────────────────────────
llm_cache/

# ── Benchmark outputs ─────────────────────────────────────────
# Per-run result JSON files generated by run_benchmark.py
results_*.json

# Generated dataset (reproducible via generate_dataset.py)
test_dataset.jsonl

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── Docker / runtime ──────────────────────────────────────────
# Grafana persistent storage if you add a named volume later
grafana-data/

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.env
*.log

# Custom
git-ignore
